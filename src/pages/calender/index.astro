---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCalendarPanel from '../../components/EventCalendarPanel.astro';

const navItems = [
  { href: '/', label: 'トップ' },
  { href: '/calender', label: 'カレンダー' },
];

---

<BaseLayout title="カレンダー | OneThing" navItems={navItems}>
  <section>
    <h2>活動カレンダー</h2>
    <EventCalendarPanel variant="detail" heading="OneThing 活動カレンダー" headingId="calendar-page-events" />
  </section>
</BaseLayout>
