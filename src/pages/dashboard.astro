---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import EventFeature from '../components/EventFeature.astro';
import OrgEventView from '../components/OrgEventView.astro';
import oneThingLogo from '../../img/OneThing.jpg';
import startixLogo from '../../img/STARTiX.jpg';
import {
  formatDateLabel,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';

// Local-only page. On the deployed site (GitHub Actions build) it must not be
// reachable, so redirect to the top page. Locally (astro dev / local build)
// GITHUB_ACTIONS is unset, so the dashboard renders normally.
if (process.env.GITHUB_ACTIONS) {
  return Astro.redirect('/');
}

const dashboard = await getCalendarDashboard(8);
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const upcomingVisibleLimit = 4;
const upcomingSources = [
  {
    id: 'onething',
    name: 'OneThing',
  },
  {
    id: 'startix',
    name: 'STARTiX',
  },
] as const;
const upcomingColumns = upcomingSources.map((source) => {
  const sourceEvents = dashboard.eventsBySource[source.id].filter((event) => event.uid !== featuredEvent?.uid);
  const visibleEvents = sourceEvents.slice(0, upcomingVisibleLimit);

  return {
    ...source,
    events: visibleEvents,
    sourceEventCount: sourceEvents.length,
    hiddenEventCount: Math.max(0, sourceEvents.length - visibleEvents.length),
  };
});
const hasUpcomingEvents = upcomingColumns.some((column) => column.sourceEventCount > 0);

const tokyoTimeZone = 'Asia/Tokyo';
const clockFormatter = new Intl.DateTimeFormat('ja-JP', {
  timeZone: tokyoTimeZone,
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
});
const datePartsFormatter = new Intl.DateTimeFormat('ja-JP', {
  timeZone: tokyoTimeZone,
  year: 'numeric',
  month: 'numeric',
  day: 'numeric',
  weekday: 'short',
});
const monthNumberFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: tokyoTimeZone,
  month: 'numeric',
});
const dayFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: tokyoTimeZone,
  day: '2-digit',
});

const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
const getSourceBadgeClass = (sourceId: string, variant?: string) =>
  ['dash-source-badge', variant ? `dash-source-badge--${variant}` : '', `dash-source-badge--${sourceId}`]
    .filter(Boolean)
    .join(' ');
const formatDashboardDate = (date: Date) => {
  const parts = datePartsFormatter.formatToParts(date);
  const getPart = (type: string) => parts.find((part) => part.type === type)?.value ?? '';

  return `${getPart('year')}/${getPart('month')}/${getPart('day')}（${getPart('weekday')}）`;
};
const clockScript = `
(() => {
  const clock = document.querySelector('[data-dashboard-clock]');
  const date = document.querySelector('[data-dashboard-date]');
  const clockFormatter = new Intl.DateTimeFormat('ja-JP', {
    timeZone: 'Asia/Tokyo',
    hour: '2-digit',
    minute: '2-digit',
    hourCycle: 'h23',
  });
  const datePartsFormatter = new Intl.DateTimeFormat('ja-JP', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: 'numeric',
    day: 'numeric',
    weekday: 'short',
  });
  const formatDashboardDate = (value) => {
    const parts = datePartsFormatter.formatToParts(value);
    const getPart = (type) => parts.find((part) => part.type === type)?.value ?? '';

    return \`\${getPart('year')}/\${getPart('month')}/\${getPart('day')}（\${getPart('weekday')}）\`;
  };
  const updateClock = () => {
    const now = new Date();
    if (clock) {
      clock.textContent = clockFormatter.format(now);
      clock.setAttribute('datetime', now.toISOString());
    }
    if (date) {
      date.textContent = formatDashboardDate(now);
      date.setAttribute('datetime', now.toISOString());
    }
  };

  updateClock();
  window.setInterval(updateClock, 1000);
})();
`;
// Drives the decorative top progress bar, synced to the wall clock: width is
// the elapsed fraction of the current minute, so it hits 0% the instant the
// minute changes and 100% as it rolls over (in step with the clock display).
// 1-minute cycle. When view rotation is added later, swap this for progress
// synced to the active-view switch.
const progressScript = `
(() => {
  const bar = document.querySelector('[data-dashboard-progress]');
  if (!bar) return;
  const update = () => {
    const now = new Date();
    const fraction = (now.getSeconds() + now.getMilliseconds() / 1000) / 60;
    bar.style.width = fraction * 100 + '%';
  };
  update();
  window.setInterval(update, 100);
})();
`;
// View rotation, one_screen style: 結合ビュー → OneThing → STARTiX → ループ。
// 自動送りは分が変わる瞬間(プログレスバーが一巡するタイミング)に同期。
// ←/→ で前後送り、Space で次へ、p で自動送りの一時停止。
const rotationScript = `
(() => {
  const views = Array.from(document.querySelectorAll('[data-dash-view]'));
  const dots = Array.from(document.querySelectorAll('[data-dash-dot]'));
  const pausedTag = document.querySelector('[data-dash-paused]');
  const titleEl = document.querySelector('[data-dash-title]');
  if (views.length === 0) return;

  const titles = ['OneCalendar', 'OneThing', 'STARTiX'];
  const hashIndex = { '#onething': 1, '#startix': 2 };
  let current = hashIndex[window.location.hash] ?? 0;
  let paused = false;

  const render = () => {
    views.forEach((view, i) => view.classList.toggle('active', i === current));
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === current);
      dot.setAttribute('aria-current', i === current ? 'true' : 'false');
    });
    if (titleEl && titles[current]) titleEl.textContent = titles[current];
    if (pausedTag) pausedTag.style.display = paused ? '' : 'none';
  };

  const go = (index) => { current = (index + views.length) % views.length; render(); };
  const next = () => go(current + 1);
  const prev = () => go(current - 1);

  dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

  window.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowRight' || event.key === ' ') { event.preventDefault(); next(); }
    else if (event.key === 'ArrowLeft') { event.preventDefault(); prev(); }
    else if (event.key === 'p' || event.key === 'P') { paused = !paused; render(); }
  });

  let lastMinute = new Date().getMinutes();
  window.setInterval(() => {
    const minute = new Date().getMinutes();
    if (minute !== lastMinute) {
      lastMinute = minute;
      if (!paused) next();
    }
  }, 200);

  render();
})();
`;
// Shrink-to-fit: keep long titles / place names on a single line by reducing the
// font size until they fit, instead of wrapping or truncating with an ellipsis.
const fitTextScript = `
(() => {
  const TARGETS = [
    { selector: '.dash-event-title', min: 24 },
    { selector: '.dash-event-info-card strong', min: 16 },
    { selector: '.dash-event-row-body h3', min: 12 },
  ];
  const fit = (el, min) => {
    el.style.fontSize = '';
    let size = parseFloat(window.getComputedStyle(el).fontSize) || 16;
    let guard = 0;
    while (el.scrollWidth > el.clientWidth && size > min && guard < 400) {
      size -= 1;
      el.style.fontSize = size + 'px';
      guard++;
    }
  };
  const run = () => {
    TARGETS.forEach((target) => {
      document.querySelectorAll(target.selector).forEach((el) => fit(el, target.min));
    });
  };
  run();
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(run);
  window.addEventListener('load', run);
  window.addEventListener('resize', run);
})();
`;
---

<DashboardLayout title="Dashboard | OneThing" refreshSeconds={3600}>
  <h1 class="sr-only">OneThing Event Dashboard</h1>

  <section class="dash-root" aria-label="OneThing dashboard">
    <div class="dash-progress" data-dashboard-progress style="width: 0%"></div>
    <div class="dash-container">
      <header class="dash-header">
        <div class="dash-header-left">
          <h2 class="dash-title" data-dash-title>OneCalendar</h2>
          <span class="dash-live">
            <span class="dash-live-dot"></span>
            LIVE
          </span>
        </div>
        <div class="dash-header-right">
          <time class="dash-clock" data-dashboard-clock datetime={dashboard.fetchedAt.toISOString()}>
            {clockFormatter.format(dashboard.fetchedAt)}
          </time>
          <time class="dash-date" data-dashboard-date datetime={dashboard.fetchedAt.toISOString()}>
            {formatDashboardDate(dashboard.fetchedAt)}
          </time>
        </div>
      </header>

      <div class="dash-main">
        <section class="dash-view active" data-dash-view aria-labelledby="next-event-title">
          <EventFeature
            event={featuredEvent}
            now={dashboard.fetchedAt}
            titleLabel="次のイベント"
            titleId="next-event-title"
          />

          {featuredEvent && <div class="dash-schedule-separator" aria-hidden="true"></div>}

          {
            dashboard.fetchError ? (
              <p class="dash-message-error">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
            ) : null
          }

          {
            hasUpcomingEvents ? (
              <div class="dash-upcoming-columns">
                {upcomingColumns.map((column) => (
                  <section class="dash-upcoming-column" aria-labelledby={`dash-upcoming-${column.id}`}>
                    <header class="dash-upcoming-column-header">
                      <h3 id={`dash-upcoming-${column.id}`}>
                        <span class={getSourceBadgeClass(column.id)}>{column.name}</span>
                      </h3>
                    </header>

                    {column.events.length > 0 ? (
                      <>
                        <div class="dash-timeline-list dash-upcoming-list">
                          {column.events.map((event) => (
                            <article class="dash-timeline-row dash-event-row">
                              <time class="dash-timeline-name" datetime={event.start.toISOString()}>
                                {formatDateLabel(event.start)} {formatWeekday(event.start)}
                              </time>
                              <div class="dash-timeline-duration">{formatTimeRange(event)}</div>
                              <div class="dash-event-row-body">
                                <h3>{formatDisplaySummary(event.summary)}</h3>
                                <p>{event.locationShort}</p>
                              </div>
                            </article>
                          ))}
                        </div>
                        {column.hiddenEventCount > 0 && (
                          <div class="dash-upcoming-more">他{column.hiddenEventCount}件</div>
                        )}
                      </>
                    ) : (
                      <div class="dash-empty dash-upcoming-column-empty">
                        <div class="dash-empty-text">この後の予定はありません</div>
                      </div>
                    )}
                  </section>
                ))}
              </div>
            ) : (
              <div class="dash-empty dash-upcoming-empty">
                <div class="dash-empty-text">この後の予定はありません</div>
              </div>
            )
          }
        </section>

        <section class="dash-view" data-dash-view aria-labelledby="org-onething-next-title">
          <OrgEventView
            sourceId="onething"
            sourceName="OneThing"
            logoSrc={oneThingLogo.src}
            events={dashboard.eventsBySource.onething}
            now={dashboard.fetchedAt}
          />
        </section>

        <section class="dash-view" data-dash-view aria-labelledby="org-startix-next-title">
          <OrgEventView
            sourceId="startix"
            sourceName="STARTiX"
            logoSrc={startixLogo.src}
            events={dashboard.eventsBySource.startix}
            now={dashboard.fetchedAt}
          />
        </section>
      </div>

      <footer class="dash-footer">
        <div class="dash-dots">
          <button type="button" class="dash-dot active" data-dash-dot aria-label="結合ビュー"></button>
          <button type="button" class="dash-dot" data-dash-dot aria-label="OneThing"></button>
          <button type="button" class="dash-dot" data-dash-dot aria-label="STARTiX"></button>
        </div>
        <div class="dash-footer-info">
          <span data-dash-paused style="display: none; margin-right: 8px;">⏸ 一時停止中</span>
          最終更新 {formatFetchedAt(dashboard.fetchedAt)}
        </div>
      </footer>
    </div>
  </section>

  <div class="dash-device-notice" role="status" aria-live="polite">
    <p>（PC・タブレットのみ対応しております）</p>
    <a href="/">トップへ戻る</a>
  </div>

  <script is:inline set:html={clockScript}></script>
  <script is:inline set:html={progressScript}></script>
  <script is:inline set:html={rotationScript}></script>
  <script is:inline set:html={fitTextScript}></script>
</DashboardLayout>
