---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import {
  formatDateLabel,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';

const dashboard = await getCalendarDashboard(8);
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const upcomingVisibleLimit = 4;
const upcomingSources = [
  {
    id: 'onething',
    name: 'OneThing',
  },
  {
    id: 'startix',
    name: 'STARTiX',
  },
] as const;
const upcomingColumns = upcomingSources.map((source) => {
  const sourceEvents = dashboard.eventsBySource[source.id].filter((event) => event.uid !== featuredEvent?.uid);
  const visibleEvents = sourceEvents.slice(0, upcomingVisibleLimit);

  return {
    ...source,
    events: visibleEvents,
    sourceEventCount: sourceEvents.length,
    hiddenEventCount: Math.max(0, sourceEvents.length - visibleEvents.length),
  };
});
const hasUpcomingEvents = upcomingColumns.some((column) => column.sourceEventCount > 0);

const tokyoTimeZone = 'Asia/Tokyo';
const clockFormatter = new Intl.DateTimeFormat('ja-JP', {
  timeZone: tokyoTimeZone,
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
});
const datePartsFormatter = new Intl.DateTimeFormat('ja-JP', {
  timeZone: tokyoTimeZone,
  year: 'numeric',
  month: 'numeric',
  day: 'numeric',
  weekday: 'short',
});
const monthNumberFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: tokyoTimeZone,
  month: 'numeric',
});
const dayFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: tokyoTimeZone,
  day: '2-digit',
});

const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
const getSourceBadgeClass = (sourceId: string, variant?: string) =>
  ['dash-source-badge', variant ? `dash-source-badge--${variant}` : '', `dash-source-badge--${sourceId}`]
    .filter(Boolean)
    .join(' ');
const formatDashboardDate = (date: Date) => {
  const parts = datePartsFormatter.formatToParts(date);
  const getPart = (type: string) => parts.find((part) => part.type === type)?.value ?? '';

  return `${getPart('year')}/${getPart('month')}/${getPart('day')}（${getPart('weekday')}）`;
};
const clockScript = `
(() => {
  const clock = document.querySelector('[data-dashboard-clock]');
  const date = document.querySelector('[data-dashboard-date]');
  const clockFormatter = new Intl.DateTimeFormat('ja-JP', {
    timeZone: 'Asia/Tokyo',
    hour: '2-digit',
    minute: '2-digit',
    hourCycle: 'h23',
  });
  const datePartsFormatter = new Intl.DateTimeFormat('ja-JP', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: 'numeric',
    day: 'numeric',
    weekday: 'short',
  });
  const formatDashboardDate = (value) => {
    const parts = datePartsFormatter.formatToParts(value);
    const getPart = (type) => parts.find((part) => part.type === type)?.value ?? '';

    return \`\${getPart('year')}/\${getPart('month')}/\${getPart('day')}（\${getPart('weekday')}）\`;
  };
  const updateClock = () => {
    const now = new Date();
    if (clock) {
      clock.textContent = clockFormatter.format(now);
      clock.setAttribute('datetime', now.toISOString());
    }
    if (date) {
      date.textContent = formatDashboardDate(now);
      date.setAttribute('datetime', now.toISOString());
    }
  };

  updateClock();
  window.setInterval(updateClock, 1000);
})();
`;
---

<DashboardLayout title="Dashboard | OneThing" refreshSeconds={3600}>
  <h1 class="sr-only">OneThing Event Dashboard</h1>

  <section class="dash-root" aria-label="OneThing dashboard">
    <div class="dash-container">
      <header class="dash-header">
        <div class="dash-header-left">
          <h2 class="dash-title">OneThing</h2>
        </div>
        <div class="dash-header-right">
          <time class="dash-clock" data-dashboard-clock datetime={dashboard.fetchedAt.toISOString()}>
            {clockFormatter.format(dashboard.fetchedAt)}
          </time>
          <time class="dash-date" data-dashboard-date datetime={dashboard.fetchedAt.toISOString()}>
            {formatDashboardDate(dashboard.fetchedAt)}
          </time>
        </div>
      </header>

      <div class="dash-main">
        <section class="dash-view active" aria-labelledby="next-event-title">
          <div class="dash-view-title">次のイベント</div>

          {
            featuredEvent ? (
              <>
                <div class="dash-presence-summary dash-event-summary">
                  <time class="dash-next-date" datetime={featuredEvent.start.toISOString()}>
                    <span>{monthNumberFormatter.format(featuredEvent.start)}/</span>
                    <strong>{dayFormatter.format(featuredEvent.start)}</strong>
                  </time>
                  <div class="dash-next-calendar">
                    <strong>{formatWeekday(featuredEvent.start)}</strong>
                  </div>
                  <div class="dash-event-heading">
                    <h2 id="next-event-title" class="dash-event-title">
                      {formatDisplaySummary(featuredEvent.summary)}
                    </h2>
                  </div>
                  <div class="dash-event-meta">
                    <span class={getSourceBadgeClass(featuredEvent.source.id, 'featured')}>
                      {featuredEvent.source.name}
                    </span>
                    <div class="dash-relative-day">{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</div>
                  </div>
                </div>

                <div class="dash-event-info-grid">
                  <article class="dash-event-info-card dash-event-info-card--time">
                    <span>時間</span>
                    <strong>{formatTimeRange(featuredEvent)}</strong>
                  </article>

                  <article class="dash-event-info-card dash-event-info-card--place">
                    <span>場所</span>
                    <strong>{featuredEvent.locationShort}</strong>
                  </article>
                </div>

                {featuredEvent.shortDescription && (
                  <p class="dash-presence-card dash-event-description">{featuredEvent.shortDescription}</p>
                )}
              </>
            ) : (
              <div class="dash-empty">
                <div class="dash-empty-text">予定されているイベントはありません</div>
              </div>
            )
          }

          {featuredEvent && <div class="dash-schedule-separator" aria-hidden="true"></div>}

          {
            dashboard.fetchError ? (
              <p class="dash-message-error">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
            ) : null
          }

          {
            hasUpcomingEvents ? (
              <div class="dash-upcoming-columns">
                {upcomingColumns.map((column) => (
                  <section class="dash-upcoming-column" aria-labelledby={`dash-upcoming-${column.id}`}>
                    <header class="dash-upcoming-column-header">
                      <h3 id={`dash-upcoming-${column.id}`}>
                        <span class={getSourceBadgeClass(column.id)}>{column.name}</span>
                      </h3>
                    </header>

                    {column.events.length > 0 ? (
                      <>
                        <div class="dash-timeline-list dash-upcoming-list">
                          {column.events.map((event) => (
                            <article class="dash-timeline-row dash-event-row">
                              <time class="dash-timeline-name" datetime={event.start.toISOString()}>
                                {formatDateLabel(event.start)} {formatWeekday(event.start)}
                              </time>
                              <div class="dash-timeline-duration">{formatTimeRange(event)}</div>
                              <div class="dash-event-row-body">
                                <h3>{formatDisplaySummary(event.summary)}</h3>
                                <p>{event.locationShort}</p>
                              </div>
                            </article>
                          ))}
                        </div>
                        {column.hiddenEventCount > 0 && (
                          <div class="dash-upcoming-more">他{column.hiddenEventCount}件</div>
                        )}
                      </>
                    ) : (
                      <div class="dash-empty dash-upcoming-column-empty">
                        <div class="dash-empty-text">この後の予定はありません</div>
                      </div>
                    )}
                  </section>
                ))}
              </div>
            ) : (
              <div class="dash-empty dash-upcoming-empty">
                <div class="dash-empty-text">この後の予定はありません</div>
              </div>
            )
          }
        </section>
      </div>

      <footer class="dash-footer">
        <div class="dash-dots" aria-hidden="true">
          <span class="dash-dot active"></span>
        </div>
        <div class="dash-footer-info">
          最終更新 {formatFetchedAt(dashboard.fetchedAt)}
          {dashboard.sources.map((source) => (
            <a href={source.url} class="dash-back-link">{source.name} ICS</a>
          ))}
        </div>
      </footer>
    </div>
  </section>

  <div class="dash-device-notice" role="status" aria-live="polite">
    <p>（PC・タブレットのみ対応しております）</p>
    <a href="/">トップへ戻る</a>
  </div>

  <script is:inline set:html={clockScript}></script>
</DashboardLayout>
