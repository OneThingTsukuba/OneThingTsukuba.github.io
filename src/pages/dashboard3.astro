---
import DashboardVariantLayout from '../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';
import '../styles/dashboard3.css';

const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title="Dashboard 3 | OneThing" bodyClass="dashboard3-page" refreshSeconds={3600}>
  <main class="d3-stage">
    <section class="d3-now" aria-labelledby="d3-next-title">
      <div class="d3-label">Next Up</div>
      <h1 id="d3-next-title">次のイベント</h1>

      {
        featuredEvent ? (
          <article class="d3-feature">
            <time datetime={featuredEvent.start.toISOString()}>
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </time>
            <div class="d3-feature-text">
              <h2>{formatDisplaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
              {featuredEvent.url && <a href={featuredEvent.url}>イベントページ</a>}
            </div>
          </article>
        ) : (
          <div class="d3-empty">Coming Soon</div>
        )
      }
    </section>

    <section class="d3-feed" aria-labelledby="d3-timeline-title">
      <div class="d3-feed-head">
        <div>
          <div class="d3-label">Timeline</div>
          <h2 id="d3-timeline-title">今後の予定</h2>
        </div>
        <span>{dashboard.allEventCount}件</span>
      </div>

      {
        dashboard.fetchError ? (
          <p class="d3-alert">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
        ) : (
          <div class="d3-list">
            {events.map((event) => (
              <article class="d3-card">
                <time datetime={event.start.toISOString()}>{formatDateLabel(event.start)} {formatWeekday(event.start)}</time>
                <div>
                  <h3>{formatDisplaySummary(event.summary)}</h3>
                  <p>{formatRelativeDay(event, dashboard.fetchedAt)} / {formatTimeRange(event)} / {event.locationShort}</p>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </section>

    <p class="d3-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
