---
import DashboardVariantLayout from '../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';
import '../styles/dashboard2.css';

const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title="Dashboard 2 | OneThing" bodyClass="dashboard2-page" refreshSeconds={3600}>
  <main class="d2-shell">
    <section class="d2-next" aria-labelledby="d2-next-title">
      <header class="d2-section-head">
        <p>Next Up</p>
        <h1 id="d2-next-title">次のイベント</h1>
      </header>

      {
        featuredEvent ? (
          <article class="d2-feature">
            <div class="d2-date">
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </div>
            <div class="d2-feature-body">
              <h2>{formatDisplaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
              {featuredEvent.url && <a href={featuredEvent.url}>イベントページ</a>}
            </div>
          </article>
        ) : (
          <div class="d2-empty">Coming Soon</div>
        )
      }
    </section>

    <section class="d2-timeline" aria-labelledby="d2-timeline-title">
      <header class="d2-section-head d2-section-head--row">
        <div>
          <p>Timeline</p>
          <h2 id="d2-timeline-title">今後の予定</h2>
        </div>
        <span>{dashboard.allEventCount}件</span>
      </header>

      {
        dashboard.fetchError ? (
          <p class="d2-alert">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
        ) : (
          <div class="d2-list">
            {events.map((event) => (
              <article class="d2-row">
                <time datetime={event.start.toISOString()}>
                  <strong>{formatDateLabel(event.start)}</strong>
                  <span>{formatWeekday(event.start)}</span>
                </time>
                <div>
                  <p>{formatRelativeDay(event, dashboard.fetchedAt)} / {formatTimeRange(event)}</p>
                  <h3>{formatDisplaySummary(event.summary)}</h3>
                  <small>{event.locationShort}</small>
                </div>
                {event.url && <a href={event.url} aria-label={`${event.summary}のイベントページへ`}>Open</a>}
              </article>
            ))}
          </div>
        )
      }
    </section>

    <p class="d2-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
