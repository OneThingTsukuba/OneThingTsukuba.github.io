---
import DashboardVariantLayout from '../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';
import '../styles/dashboard4.css';

const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title="Dashboard 4 | OneThing" bodyClass="dashboard4-page" refreshSeconds={3600}>
  <main class="d4-board">
    <section class="d4-panel d4-panel--next" aria-labelledby="d4-next-title">
      <header>
        <p>Next Up</p>
        <h1 id="d4-next-title">次のイベント</h1>
      </header>

      {
        featuredEvent ? (
          <article class="d4-feature">
            <time datetime={featuredEvent.start.toISOString()}>
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </time>
            <div>
              <h2>{formatDisplaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
              {featuredEvent.url && <a href={featuredEvent.url}>イベントページ</a>}
            </div>
          </article>
        ) : (
          <div class="d4-empty">Coming Soon</div>
        )
      }
    </section>

    <section class="d4-panel d4-panel--timeline" aria-labelledby="d4-timeline-title">
      <header>
        <p>Timeline</p>
        <h2 id="d4-timeline-title">今後の予定</h2>
        <span>{dashboard.allEventCount}件</span>
      </header>

      {
        dashboard.fetchError ? (
          <p class="d4-alert">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
        ) : (
          <div class="d4-table">
            {events.map((event) => (
              <article>
                <time datetime={event.start.toISOString()}>{formatDateLabel(event.start)} {formatWeekday(event.start)}</time>
                <strong>{formatDisplaySummary(event.summary)}</strong>
                <small>{formatRelativeDay(event, dashboard.fetchedAt)} / {formatTimeRange(event)} / {event.locationShort}</small>
              </article>
            ))}
          </div>
        )
      }
    </section>

    <p class="d4-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
