---
import '../styles/global.css';
import '../styles/dashboard.css';

interface Props {
  title: string;
  refreshSeconds?: number;
}

const { title, refreshSeconds } = Astro.props;
const refreshDelayMs = refreshSeconds ? refreshSeconds * 1000 : 0;
const refreshScript = `window.setTimeout(() => window.location.reload(), ${refreshDelayMs});`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="OneThingの今後のイベントを確認できるダッシュボードです。" />
    <title>{title}</title>
  </head>
  <body class="dashboard-page">
    <main class="dashboard-main">
      <slot />
    </main>
    {refreshDelayMs > 0 && <script is:inline set:html={refreshScript}></script>}
  </body>
</html>
