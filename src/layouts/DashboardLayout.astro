---
import '../styles/global.css';
import '../styles/dashboard.css';
import DashboardDesignSwitcher from '../components/DashboardDesignSwitcher.astro';

interface Props {
  title: string;
  refreshSeconds?: number;
}

const { title, refreshSeconds } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="OneThingの今後のイベントを確認できるダッシュボードです。" />
    <title>{title}</title>
  </head>
  <body class="dashboard-page">
    <main class="dashboard-main">
      <slot />
    </main>
    <DashboardDesignSwitcher refreshSeconds={refreshSeconds} />
  </body>
</html>
