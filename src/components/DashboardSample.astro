---
import DashboardVariantLayout from '../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../lib/calendar';
import '../styles/dashboard-samples.css';

interface Props {
  variant: number;
  title: string;
}

const { variant, title } = Astro.props;
const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title={`${title} | OneThing`} bodyClass={`sample-page sample-v${variant}`} refreshSeconds={3600}>
  <main class="sample-shell">
    <section class="sample-next" aria-labelledby={`sample-next-${variant}`}>
      <header class="sample-heading">
        <p>Next Up</p>
        <h1 id={`sample-next-${variant}`}>次のイベント</h1>
      </header>

      {
        featuredEvent ? (
          <article class={`sample-feature sample-feature--${featuredEvent.kind}`}>
            <time class="sample-date" datetime={featuredEvent.start.toISOString()}>
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </time>
            <div class="sample-event">
              <h2>{formatDisplaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
              {featuredEvent.shortDescription && <p class="sample-description">{featuredEvent.shortDescription}</p>}
              {featuredEvent.url && (
                <div class="sample-actions">
                  <a href={featuredEvent.url}>イベントページ</a>
                </div>
              )}
            </div>
          </article>
        ) : (
          <div class="sample-empty">
            <span>Coming Soon</span>
          </div>
        )
      }
    </section>

    <section class="sample-timeline" aria-labelledby={`sample-timeline-${variant}`}>
      <header class="sample-heading sample-heading--row">
        <div>
          <p>Timeline</p>
          <h2 id={`sample-timeline-${variant}`}>今後の予定</h2>
        </div>
        <span>{dashboard.allEventCount}件</span>
      </header>

      {
        dashboard.fetchError ? (
          <p class="sample-alert">カレンダーの取得に失敗しました: {dashboard.fetchError}</p>
        ) : (
          <div class="sample-list">
            {events.map((event) => (
              <article class={`sample-row sample-row--${event.kind}`}>
                <time datetime={event.start.toISOString()}>
                  <strong>{formatDateLabel(event.start)}</strong>
                  <span>{formatWeekday(event.start)}</span>
                </time>
                <div>
                  <div class="sample-meta">
                    <span>{formatRelativeDay(event, dashboard.fetchedAt)}</span>
                    <span>{formatTimeRange(event)}</span>
                  </div>
                  <h3>{formatDisplaySummary(event.summary)}</h3>
                  <p>{event.locationShort}</p>
                </div>
                {event.url && <a class="sample-open" href={event.url} aria-label={`${event.summary}のイベントページへ`}>Open</a>}
              </article>
            ))}
          </div>
        )
      }
    </section>

    <p class="sample-sync">
      Last Sync <time datetime={dashboard.fetchedAt.toISOString()}>{formatFetchedAt(dashboard.fetchedAt)}</time> / <a href={dashboard.sourceUrl}>ICS</a>
    </p>
  </main>
</DashboardVariantLayout>
