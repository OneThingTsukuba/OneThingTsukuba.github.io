---
import EventFeature from './EventFeature.astro';
import { formatDateLabel, formatTimeRange, formatWeekday } from '../lib/calendar';
import type { CalendarEvent, CalendarSourceId } from '../lib/calendar';

interface Props {
  sourceId: CalendarSourceId;
  sourceName: string;
  logoSrc: string;
  events: CalendarEvent[];
  now: Date;
  upcomingLimit?: number;
}

const { sourceId, sourceName, logoSrc, events, now, upcomingLimit = 5 } = Astro.props;

const featuredEvent = events[0] ?? null;
const upcomingEvents = events.slice(1, 1 + upcomingLimit);
const hiddenEventCount = Math.max(0, events.length - 1 - upcomingEvents.length);

const formatDisplaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, ' $1');
const titleId = `org-${sourceId}-next-title`;
---

<div class="dash-org">
  <div class="dash-org-logo">
    <img src={logoSrc} alt={`${sourceName} のロゴ`} />
  </div>

  <div class="dash-org-body">
    <EventFeature event={featuredEvent} now={now} titleLabel="次のイベント" titleId={titleId} showSourceBadge={false} />

    {featuredEvent && <div class="dash-schedule-separator" aria-hidden="true"></div>}

    {
      upcomingEvents.length > 0 ? (
        <section class="dash-upcoming-column" aria-label={`${sourceName} のこの後の予定`}>
          <div class="dash-timeline-list dash-upcoming-list">
            {upcomingEvents.map((event) => (
              <article class="dash-timeline-row dash-event-row">
                <time class="dash-timeline-name" datetime={event.start.toISOString()}>
                  {formatDateLabel(event.start)} {formatWeekday(event.start)}
                </time>
                <div class="dash-timeline-duration">{formatTimeRange(event)}</div>
                <div class="dash-event-row-body">
                  <h3>{formatDisplaySummary(event.summary)}</h3>
                  <p>{event.locationShort}</p>
                </div>
              </article>
            ))}
          </div>

          {hiddenEventCount > 0 && <div class="dash-upcoming-more">他{hiddenEventCount}件</div>}
        </section>
      ) : (
        featuredEvent && (
          <div class="dash-empty dash-upcoming-column-empty">
            <div class="dash-empty-text">この後の予定はありません</div>
          </div>
        )
      )
    }
  </div>
</div>
