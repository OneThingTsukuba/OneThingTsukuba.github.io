---
interface Props {
  refreshSeconds?: number;
  totalDesigns?: number;
}

const { refreshSeconds, totalDesigns = 100 } = Astro.props;
const dashboardPaths = Array.from({ length: totalDesigns }, (_, index) => (index === 0 ? '/dashboard' : `/dashboard${index + 1}`));
const refreshDelayMs = refreshSeconds ? refreshSeconds * 1000 : 0;
const switcherScript = `
(() => {
  const dashboardPaths = ${JSON.stringify(dashboardPaths)};
  const refreshDelayMs = ${refreshDelayMs};
  const totalDesigns = dashboardPaths.length;
  const switcher = document.querySelector('[data-dashboard-switcher]');
  const count = document.querySelector('[data-dashboard-design-count]');
  const nextControl = document.querySelector('[data-dashboard-next]');

  const normalizedPath = () => window.location.pathname.replace(/\\/$/, '');
  const currentMatch = () => normalizedPath().match(/^(.*)\\/dashboard(\\d*)$/);
  const currentNumber = () => {
    const match = currentMatch();
    const number = match?.[2] ? Number(match[2]) : 1;
    return Number.isInteger(number) && number >= 1 && number <= totalDesigns ? number : 1;
  };
  const canonicalPath = (number) => (number === 1 ? '/dashboard' : \`/dashboard\${number}\`);
  const basePath = () => currentMatch()?.[1] ?? '';
  const randomNextPath = () => {
    const currentPath = canonicalPath(currentNumber());
    const candidates = dashboardPaths.filter((path) => path !== currentPath);
    return candidates[Math.floor(Math.random() * candidates.length)] || '/dashboard';
  };
  const goNext = () => {
    const nextPath = randomNextPath();
    window.location.href = \`\${basePath()}\${nextPath}\`;
  };

  if (count) {
    count.textContent = \`DESIGN \${currentNumber()}/\${totalDesigns}\`;
  }

  nextControl?.addEventListener('click', (event) => {
    event.preventDefault();
    goNext();
  });

  if (switcher) {
    switcher.hidden = false;
  }

  if (refreshDelayMs > 0) {
    window.setTimeout(goNext, refreshDelayMs);
  }
})();
`;
---

<div class="dashboard-design-switcher" data-dashboard-switcher hidden>
  <span class="dashboard-design-count" data-dashboard-design-count>DESIGN --/--</span>
  <a class="dashboard-design-next" href="/dashboard" data-dashboard-next>
    NEXT DESIGN <span aria-hidden="true">&rarr;</span>
  </a>
</div>

<script is:inline set:html={switcherScript}></script>
