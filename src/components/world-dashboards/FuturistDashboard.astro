---
import DashboardVariantLayout from '../../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../../lib/calendar';
import '../../styles/dashboard-world.css';

interface Props {
  variant: number;
  tone: number;
}

const { variant, tone } = Astro.props;
const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const displaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title={`Dashboard ${variant} | OneThing`} bodyClass={`world-dashboard world-futurist world-tone-${tone} world-v${variant}`} refreshSeconds={3600}>
  <main class="future-grid">
    <section class="future-primary" aria-labelledby={`future-next-${variant}`}>
      <div class="future-orbit"></div>
      <p class="world-kicker">Next Signal</p>
      <h1 id={`future-next-${variant}`}>次のイベント</h1>
      {
        featuredEvent ? (
          <article>
            <time datetime={featuredEvent.start.toISOString()}>
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </time>
            <div>
              <h2>{displaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
            </div>
          </article>
        ) : (
          <div class="world-empty">Coming Soon</div>
        )
      }
    </section>
    <section class="future-rail" aria-labelledby={`future-list-${variant}`}>
      <header>
        <p class="world-kicker">Flight Plan</p>
        <h2 id={`future-list-${variant}`}>今後の予定</h2>
        <span>{dashboard.allEventCount}件</span>
      </header>
      {events.map((event) => (
        <article>
          <time datetime={event.start.toISOString()}>{formatDateLabel(event.start)}</time>
          <div>
            <h3>{displaySummary(event.summary)}</h3>
            <p>{formatWeekday(event.start)} / {formatRelativeDay(event, dashboard.fetchedAt)} / {formatTimeRange(event)}</p>
          </div>
        </article>
      ))}
    </section>
    <p class="world-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
