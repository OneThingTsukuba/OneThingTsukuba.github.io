---
import DashboardVariantLayout from '../../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../../lib/calendar';
import '../../styles/dashboard-world.css';

interface Props {
  variant: number;
  tone: number;
}

const { variant, tone } = Astro.props;
const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const displaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title={`Dashboard ${variant} | OneThing`} bodyClass={`world-dashboard world-cyber world-tone-${tone} world-v${variant}`} refreshSeconds={3600}>
  <main class="cyber-console">
    <section class="cyber-main" aria-labelledby={`cyber-next-${variant}`}>
      <p class="world-kicker">Live Queue</p>
      <h1 id={`cyber-next-${variant}`}>次のイベント</h1>
      {
        featuredEvent ? (
          <article>
            <div class="cyber-date">
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <time datetime={featuredEvent.start.toISOString()}>{formatDateLabel(featuredEvent.start)}</time>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </div>
            <h2>{displaySummary(featuredEvent.summary)}</h2>
            <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
            <p>{featuredEvent.locationShort}</p>
          </article>
        ) : (
          <div class="world-empty">Coming Soon</div>
        )
      }
    </section>
    <section class="cyber-stack" aria-labelledby={`cyber-list-${variant}`}>
      <header>
        <p class="world-kicker">Event Stack</p>
        <h2 id={`cyber-list-${variant}`}>今後の予定</h2>
        <span>{dashboard.allEventCount}件</span>
      </header>
      {events.map((event) => (
        <article>
          <code>{formatRelativeDay(event, dashboard.fetchedAt)}</code>
          <div>
            <h3>{displaySummary(event.summary)}</h3>
            <p>{formatDateLabel(event.start)} {formatWeekday(event.start)} / {formatTimeRange(event)} / {event.locationShort}</p>
          </div>
        </article>
      ))}
    </section>
    <p class="world-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
