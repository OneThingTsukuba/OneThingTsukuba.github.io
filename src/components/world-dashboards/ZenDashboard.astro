---
import DashboardVariantLayout from '../../layouts/DashboardVariantLayout.astro';
import {
  formatDateLabel,
  formatDuration,
  formatFetchedAt,
  formatRelativeDay,
  formatTimeRange,
  formatWeekday,
  getCalendarDashboard,
} from '../../lib/calendar';
import '../../styles/dashboard-world.css';

interface Props {
  variant: number;
  tone: number;
}

const { variant, tone } = Astro.props;
const dashboard = await getCalendarDashboard();
const events = dashboard.events;
const featuredEvent = events[0] ?? null;
const displaySummary = (summary: string) => summary.replace(/\s+(#\d+)/, '\u00a0$1');
---

<DashboardVariantLayout title={`Dashboard ${variant} | OneThing`} bodyClass={`world-dashboard world-zen world-tone-${tone} world-v${variant}`} refreshSeconds={3600}>
  <main class="zen-board">
    <section class="zen-next" aria-labelledby={`zen-next-${variant}`}>
      <p class="world-kicker">Next Up</p>
      <h1 id={`zen-next-${variant}`}>次のイベント</h1>
      {
        featuredEvent ? (
          <article class="zen-feature">
            <time class="zen-date" datetime={featuredEvent.start.toISOString()}>
              <span>{formatRelativeDay(featuredEvent, dashboard.fetchedAt)}</span>
              <strong>{formatDateLabel(featuredEvent.start)}</strong>
              <small>{formatWeekday(featuredEvent.start)}</small>
            </time>
            <div class="zen-copy">
              <h2>{displaySummary(featuredEvent.summary)}</h2>
              <p>{formatTimeRange(featuredEvent)} / {formatDuration(featuredEvent)}</p>
              <p>{featuredEvent.locationShort}</p>
              {featuredEvent.url && <a href={featuredEvent.url}>イベントページ</a>}
            </div>
          </article>
        ) : (
          <div class="world-empty">Coming Soon</div>
        )
      }
    </section>
    <section class="zen-scroll" aria-labelledby={`zen-list-${variant}`}>
      <header>
        <p class="world-kicker">Timeline</p>
        <h2 id={`zen-list-${variant}`}>今後の予定</h2>
        <span>{dashboard.allEventCount}件</span>
      </header>
      <div class="zen-list">
        {events.map((event) => (
          <article>
            <time datetime={event.start.toISOString()}>{formatDateLabel(event.start)} {formatWeekday(event.start)}</time>
            <h3>{displaySummary(event.summary)}</h3>
            <p>{formatRelativeDay(event, dashboard.fetchedAt)} / {formatTimeRange(event)} / {event.locationShort}</p>
          </article>
        ))}
      </div>
    </section>
    <p class="world-sync">Last Sync {formatFetchedAt(dashboard.fetchedAt)} / <a href={dashboard.sourceUrl}>ICS</a></p>
  </main>
</DashboardVariantLayout>
